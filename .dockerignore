# Arquivos excluídos do contexto do Docker build.
# Mantém a imagem enxuta e evita vazar dados sensíveis.

# Controle de versão
.git/
.gitignore

# Ambiente e segredos
.env
.env.*
!.env.example

# Cache e artefatos de desenvolvimento
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Dados brutos e processados (montados via volume ou DVC)
data/raw/
data/processed/

# Checkpoints de modelo (gerenciados via MLflow/DVC)
models/
mlruns/
mlartifacts/

# Notebooks (não fazem parte da imagem de produção)
notebooks/

# Documentação
docs/

# IDEs
.vscode/
.idea/
