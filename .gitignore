# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# =============================================================================
# Ambientes virtuais
# =============================================================================
.venv/
venv/
env/
.env
# .env.example NÃO é ignorado — deve ser versionado

# =============================================================================
# Poetry
# =============================================================================
# poetry.lock DEVE ser versionado — não adicionar aqui

# =============================================================================
# Distribuição e build
# =============================================================================
dist/
build/
*.egg-info/
*.egg
MANIFEST

# =============================================================================
# Pytest / cobertura
# =============================================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# =============================================================================
# Ferramentas de qualidade
# =============================================================================
.ruff_cache/
.mypy_cache/

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# Dados e modelos (gerenciados por DVC na Etapa 4)
# =============================================================================
# Ignora os arquivos de dados pesados, mas permite os metadados do DVC (.dvc)
data/raw/*
!data/raw/.gitkeep
!data/raw/*.dvc
data/interim/*
!data/interim/.gitkeep
!data/interim/*.dvc
data/processed/*
!data/processed/.gitkeep
!data/processed/*.dvc
models/*
!models/.gitkeep
!models/*.dvc

# =============================================================================
# MLflow (configurado na Etapa 8)
# =============================================================================
mlruns/
mlartifacts/
mlflow.db

# =============================================================================
# Logs
# =============================================================================
*.log

# =============================================================================
# IDEs e editores
# =============================================================================
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
