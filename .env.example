# =============================================================================
# .env.example — Variáveis de ambiente do projeto
#
# 📋 Como usar:
#   1. Copie para .env:  cp .env.example .env
#   2. Ajuste os valores conforme necessário
#   3. NUNCA commite o arquivo .env
#
# Os valores padrão funcionam para desenvolvimento local.
# =============================================================================

# ── Projeto ──────────────────────────────────────────────────────────────────
PROJECT_NAME=ecommerce-recommendation-system
ENVIRONMENT=development   # development | staging | production

# ── Reprodutibilidade ─────────────────────────────────────────────────────────
RANDOM_SEED=42

# ── Caminhos de dados ────────────────────────────────────────────────────────
RAW_DATA_PATH=data/raw
INTERIM_DATA_PATH=data/interim
PROCESSED_DATA_PATH=data/processed
MODELS_PATH=models

# ── Configurações do modelo ───────────────────────────────────────────────────
TOP_K=10
# RECOMMENDER_TYPE controla qual modelo é treinado por padrão.
# Pode ser sobrescrito via CLI: python -m recsys.pipeline.train --mode neural
# Valores: baseline (SVD) | neural (NeuMF) | popularity
# O params.yaml do DVC tem prioridade quando se usa `dvc repro`.
RECOMMENDER_TYPE=baseline

# ── MLflow ───────────────────────────────────────────────────────────────────
# ⚠️  IMPORTANTE — Esta variável controla ONDE os experimentos são registrados.
#
# Para desenvolvimento LOCAL (com MLflow server via Docker):
#   MLFLOW_TRACKING_URI=http://localhost:5001
#   → Aponta para o MLflow Server exposto na porta 5001 do host.
#   → Requer: docker compose up mlflow -d  (ou: make docker-up)
#
# Para fallback SEM servidor (apenas arquivos locais):
#   MLFLOW_TRACKING_URI=mlruns
#   → Loga diretamente em ./mlruns/ (sem tracking server).
#   → Útil para testes rápidos sem Docker.
#
# 🐳 No Docker: o docker-compose.yml define MLFLOW_TRACKING_URI=http://mlflow:5000
# (endereço interno da rede Docker). Isso NÃO é uma sobrescrita destrutiva —
# ambos os endereços (localhost:5001 e mlflow:5000) apontam para o MESMO
# servidor MLflow, garantindo que todos os registros ficam UNIFICADOS
# no mesmo backend (mlruns/mlflow.db).
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=neumf-instacart

# ── Dataset ──────────────────────────────────────────────────────────────────
DATASET_NAME=instacart

# ── DVC remote ────────────────────────────────────────────────────────────────
# Descomentar e configurar quando usar DVC com storage remoto (S3, GCS, etc.)
# DVC_REMOTE_URL=s3://meu-bucket/dvc-store
