# =============================================================================
# .env.example — Variáveis de ambiente do projeto
# Copie para .env e preencha os valores reais.
# NUNCA commite o arquivo .env.
# =============================================================================

# ── Projeto ──────────────────────────────────────────────────────────────────
PROJECT_NAME=ecommerce-recommendation-system
ENVIRONMENT=development   # development | staging | production

# ── Reprodutibilidade ─────────────────────────────────────────────────────────
RANDOM_SEED=42

# ── Caminhos de dados ────────────────────────────────────────────────────────
RAW_DATA_PATH=data/raw
INTERIM_DATA_PATH=data/interim
PROCESSED_DATA_PATH=data/processed
MODELS_PATH=models

# ── Configurações do modelo ───────────────────────────────────────────────────
TOP_K=10

# ── MLflow (configurado na Etapa 8 — Eduardo) ─────────────────────────────────
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=neumf-amazon-toys

# ── Dataset ──────────────────────────────────────────────────────────────────
DATASET_NAME=instacart

# ── DVC remote (configurado na Etapa 4 — Pedro) ───────────────────────────────
# DVC_REMOTE_URL=s3://meu-bucket/dvc-store
